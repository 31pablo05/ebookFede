---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import QueEs from '../components/QueEs.astro';
import Incluye from '../components/Incluye.astro';
import ParaQuien from '../components/ParaQuien.astro';
import { CONFIG } from '../config';
import Preview from '../components/Preview.astro';
import Autor from '../components/Autor.astro';
import FAQ from '../components/islands/FAQ.jsx';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <Nav />
  <main>
    <Hero />
    <Problema />
    <QueEs />
    <Incluye />

    <!-- CTA intermedio -->
    <section style="padding:56px 5%;background:var(--color-ink);text-align:center;">
      <div style="max-width:640px;margin:0 auto;" class="fade-up">
        <p style="color:rgba(255,255,255,0.6);font-size:1rem;margin-bottom:8px;font-weight:300;">
          Todo lo que aprendés lo podés aplicar hoy, con el celular que ya tenés.
        </p>
        <p style="color:white;font-family:var(--font-serif);font-size:1.3rem;font-weight:700;margin-bottom:24px;">
          Sin estudio. Sin equipos. Sin excusas.
        </p>
        <a href={CONFIG.mercadopagoUrl} class="btn-cta">
          Quiero el ebook — {CONFIG.precioCompleto}
        </a>
      </div>
    </section>

    <ParaQuien />
    <Preview />
    <Autor />
    <section id="faq" style="background:white;padding:100px 5%;">
      <div style="max-width:1100px;margin:0 auto;">
        <p class="section-tag">Preguntas frecuentes</p>
        <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);margin-bottom:48px;max-width:500px;">
          Todo lo que necesitás<br />saber antes de comprar
        </h2>
        <FAQ client:visible />
      </div>
    </section>
    <CTAFinal />
  </main>
  <Footer />
</Layout>

<style>
  @media (max-width: 768px) {
    #faq {
      padding: 70px 5% !important;
    }
  }
</style>
