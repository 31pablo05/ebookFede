---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import QueEs from '../components/QueEs.astro';
import Incluye from '../components/Incluye.astro';
import ParaQuien from '../components/ParaQuien.astro';
import Preview from '../components/Preview.astro';
import Autor from '../components/Autor.astro';
import FAQ from '../components/islands/FAQ.jsx';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <Nav />
  <main>
    <Hero />
    <Problema />
    <QueEs />
    <Incluye />
    <ParaQuien />
    <Preview />
    <Autor />
    <section id="faq" class="section-faq">
      <div class="container">
        <p class="section-tag">Preguntas frecuentes</p>
        <h2>Todo lo que necesitás<br />saber antes de comprar</h2>
        <FAQ client:visible />
      </div>
    </section>
    <CTAFinal />
  </main>
  <Footer />
</Layout>

<style>
  .section-faq {
    background: var(--bg);
    padding: 100px 5%;
  }

  .section-faq h2 {
    margin-bottom: 48px;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .section-faq {
      padding: 70px 5%;
    }
  }
</style>
