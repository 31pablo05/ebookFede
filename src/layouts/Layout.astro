---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Fotos con Celular que Venden — Fede Forquera',
  description = 'La guía práctica para crear imágenes profesionales para redes y e-commerce sin estudio ni equipos.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="ebook fotografía celular, fotos productos celular, fotografía emprendedores argentina, fotos que venden instagram, guía fotografía celular, fede forquera" />
    <link rel="canonical" href="https://fedeforquera.com/" />
    <!-- Open Graph -->
    <meta property="og:type" content="product" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/ebook/fotosQueVenden.PNG" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://fedeforquera.com/" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Fede Forquera — Fotografía" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/ebook/fotosQueVenden.PNG" />
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Fotos con Celular que Venden",
      "description": "Guía práctica de 50 páginas para fotografiar productos con el celular. Técnicas reales de luz natural, escenografía y redes sociales para emprendedores.",
      "image": "https://fedeforquera.com/images/ebook/fotosQueVenden.PNG",
      "brand": { "@type": "Brand", "name": "Fede Forquera" },
      "author": { "@type": "Person", "name": "Fede Forquera", "url": "https://www.instagram.com/fede_forquera/" },
      "offers": {
        "@type": "Offer",
        "price": "20000",
        "priceCurrency": "ARS",
        "availability": "https://schema.org/InStock"
      }
    }
    </script>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.12 }
      );
      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
