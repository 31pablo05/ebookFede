---
const caps = [
  { n:'01', title:'Mentalidad visual', desc:'Cómo pensar la fotografía con intención antes de tocar el celular.' },
  { n:'02', title:'Luz natural bien usada', desc:'La técnica de la ventana: cómo conseguir luz perfecta sin equipos.' },
  { n:'03', title:'Escenografía simple', desc:'Fondos, props y superficies que suman sin robarle protagonismo al producto.' },
  { n:'04', title:'5 tipos de fotos', desc:'Las imágenes que realmente ayudan a vender: catálogo, contexto, uso, detalle e identidad.' },
  { n:'05', title:'Mini módulo e-commerce', desc:'Fotos para tienda online: encuadres, cantidad mínima y coherencia visual.' },
  { n:'06', title:'Instagram estratégico', desc:'Cómo sacar 7 piezas de contenido de una sola sesión fotográfica.' },
];
---
<section id="incluye" style="padding:100px 5%;background:white;">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up" style="display:flex;justify-content:space-between;
      align-items:flex-end;margin-bottom:48px;flex-wrap:wrap;gap:20px;">
      <div>
        <p class="section-tag">Contenido</p>
        <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);">
          6 capítulos para dominar<br/>la foto de producto
        </h2>
      </div>
      <p style="font-size:.875rem;color:var(--color-muted);
        max-width:280px;text-align:right;">
        Cada capítulo es concreto, visual y aplicable desde el primer momento.
      </p>
    </div>

    <div class="stagger fade-up" style="display:grid;
      grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;">
      {caps.map(c => (
        <div class="cap-card" style="padding:24px;border-radius:12px;background:var(--color-bg);
          border:1.5px solid transparent;
          transition:border-color .2s,background .2s;">
          <div style="font-family:var(--font-serif);font-size:2rem;font-weight:900;
            color:rgba(42,157,143,0.2);line-height:1;margin-bottom:12px;">
            {c.n}
          </div>
          <h3 style="font-family:var(--font-serif);font-size:1rem;
            font-weight:700;margin-bottom:8px;">{c.title}</h3>
          <p style="font-size:.8rem;color:var(--color-muted);line-height:1.55;">
            {c.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- Bonus -->
    <div class="fade-up" style="background:var(--color-teal);color:white;
      padding:20px 28px;border-radius:12px;
      display:flex;align-items:center;gap:20px;">
      <div style="font-size:1.8rem;flex-shrink:0;">✅</div>
      <div>
        <h4 style="font-family:var(--font-serif);font-size:1rem;font-weight:700;">
          Bonus — Checklist antes de cada sesión
        </h4>
        <p style="font-size:.8rem;opacity:.8;margin-top:4px;">
          5 preguntas que te aseguran que cada foto que sacás tiene intención y comunica.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .cap-card:hover {
    border-color: var(--color-teal) !important;
    background: white !important;
    box-shadow: 0 4px 20px rgba(42,157,143,0.1);
  }

  @media (max-width: 768px) {
    #incluye div[style*="grid-template-columns:repeat(3"] {
      grid-template-columns: 1fr !important;
    }
    #incluye div[style*="justify-content:space-between"] p {
      text-align: left !important;
    }
  }
</style>
