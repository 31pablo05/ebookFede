---
const pains = [
  {
    icon: '📸',
    title: 'Las fotos no hacen justicia',
    desc: 'Sacás la foto con el celular y el producto parece barato. El cliente no ve lo que vos ves cuando lo tenés en las manos.'
  },
  {
    icon: '💡',
    title: 'La luz siempre sale mal',
    desc: 'Sombras duras, colores raros, brillos quemados. No sabés bien de dónde viene el problema ni cómo arreglarlo.'
  },
  {
    icon: '🎭',
    title: 'El fondo distrae',
    desc: 'Siempre hay algo que no suma: una pared sucia, un objeto de más, un fondo que compite con el producto.'
  },
  {
    icon: '📉',
    title: 'Fotos que no venden',
    desc: 'La gente ve la foto pero no pregunta, no compra. Intuís que algo falla en la imagen pero no sabés exactamente qué.'
  }
];
---
<section id="problema" style="padding:100px 5%;background:var(--color-ink);color:white;">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up">
      <p class="section-tag" style="color:var(--color-teal);">El problema</p>
      <p style="font-family:var(--font-serif);font-size:clamp(1.8rem,3vw,2.6rem);
        font-weight:700;line-height:1.2;margin-bottom:60px;max-width:700px;">
        Tus productos son buenos.<br/>
        <em style="color:var(--color-teal);font-style:italic;">
          Las fotos no siempre los muestran así.
        </em>
      </p>
    </div>

    <div class="stagger fade-up" style="display:grid;grid-template-columns:repeat(2,1fr);
      gap:20px;margin-bottom:60px;">
      {pains.map(p => (
        <div style="background:rgba(255,255,255,0.04);
          border:1px solid rgba(255,255,255,0.08);
          padding:28px;border-radius:12px;
          transition:border-color .2s;">
          <div style="font-size:1.5rem;margin-bottom:14px;">{p.icon}</div>
          <h3 style="font-family:var(--font-serif);font-size:1.1rem;
            font-weight:700;margin-bottom:8px;">{p.title}</h3>
          <p style="font-size:.875rem;color:rgba(255,255,255,0.55);
            line-height:1.65;">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="fade-up" style="text-align:center;font-size:1.1rem;
      color:rgba(255,255,255,0.6);padding:40px;
      border-top:1px solid rgba(255,255,255,0.08);">
      Pero no es culpa de tu celular.<br/>
      <strong style="color:var(--color-teal);font-weight:500;">
        Es cuestión de saber exactamente cómo usarlo.
      </strong>
    </div>

  </div>
</section>

<style>
  @media (max-width: 768px) {
    #problema div[style*="grid-template-columns:repeat(2"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
