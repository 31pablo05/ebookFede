---
import { CONFIG } from '../config';
---
<section id="que-es" class="quees section-base">
  <div class="container">
    <span class="section-tag fade-up">La solución</span>
    <h2 class="fade-up">
      Este ebook te enseña<br />
      exactamente eso
    </h2>
    <p class="quees-lead fade-up">
      Una guía práctica de {CONFIG.ebookPaginas} páginas con técnicas reales, ejemplos visuales y videos de ejemplo.
      Todo aplicable desde el primer día, con lo que ya tenés en casa.
    </p>

    <div class="preview-grid stagger">
      <!-- Card 1 -->
      <div class="preview-card fade-up">
        <div class="preview-img gradient-teal">
          <span>☀️</span>
        </div>
        <div class="preview-body">
          <h3>Luz natural</h3>
          <p>Cómo posicionar el producto cerca de una ventana para conseguir luz perfecta siempre.</p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="preview-card fade-up">
        <div class="preview-img gradient-orange">
          <span>🎨</span>
        </div>
        <div class="preview-body">
          <h3>Escenografía simple</h3>
          <p>Fondos y props caseros que se ven profesionales. Sin gastar dinero en equipos.</p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="preview-card fade-up">
        <div class="preview-img gradient-purple">
          <span>📱</span>
        </div>
        <div class="preview-body">
          <h3>Tipos de fotos</h3>
          <p>Las 5 fotos que toda marca necesita para vender en redes y e-commerce.</p>
        </div>
      </div>
    </div>

    <div class="quees-cta fade-up">
      <a href="#cta-final" class="btn-cta">Quiero empezar ahora</a>
    </div>
  </div>
</section>

<style>
  .quees {
    background: var(--bg);
  }

  .quees h2 {
    margin-bottom: 16px;
    max-width: 540px;
  }

  .quees-lead {
    color: var(--ink-2);
    font-size: 1.05rem;
    max-width: 600px;
    margin-bottom: 56px;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .preview-card {
    background: white;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .preview-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .preview-img {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
  }

  .gradient-teal {
    background: linear-gradient(135deg, #e0f5f2 0%, #a8e6df 100%);
  }

  .gradient-orange {
    background: linear-gradient(135deg, #fef3e0 0%, #f8d89f 100%);
  }

  .gradient-purple {
    background: linear-gradient(135deg, #ede8f8 0%, #c9b8ef 100%);
  }

  .preview-body {
    padding: 20px;
  }

  .preview-body h3 {
    font-size: 1.05rem;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .preview-body p {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .quees-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
