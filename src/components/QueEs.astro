---
import { CONFIG } from '../config';

const previews = [
  { grad: 'linear-gradient(135deg,#e0f5f2,#b8ebe3)', emoji: '☀️',
    title: 'Luz natural', desc: 'Cómo posicionar el producto cerca de una ventana para conseguir luz perfecta siempre.' },
  { grad: 'linear-gradient(135deg,#faeeda,#f5d9a0)', emoji: '🎨',
    title: 'Escenografía simple', desc: 'Fondos y props caseros que se ven profesionales. Sin gastar dinero en equipos.' },
  { grad: 'linear-gradient(135deg,#f0e8ff,#dcc8f8)', emoji: '📱',
    title: 'Tipos de fotos', desc: 'Las 5 fotos que toda marca necesita para vender en redes y e-commerce.' },
];
---
<section id="que-es" style="padding:100px 5%;background:var(--color-bg);">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up">
      <p class="section-tag">La solución</p>
      <div style="display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;margin-bottom:20px;">
        <div>
          <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);margin-bottom:20px;">
            Este ebook te enseña<br/>exactamente eso
          </h2>
          <p style="font-size:1.05rem;color:var(--color-ink-2);line-height:1.7;
            margin-bottom:0;max-width:480px;font-weight:300;">
            Una guía práctica de {CONFIG.ebookPaginas} páginas con técnicas reales,
            ejemplos visuales y videos de ejemplo. Todo aplicable desde el primer día,
            con lo que ya tenés en casa.
          </p>
        </div>
        <img
          src="/images/ebook/fotosQueVenden.PNG"
          alt="Primera página del ebook Fotos con Celular que Venden"
          style="width:200px;border-radius:10px;
            box-shadow:0 8px 32px rgba(0,0,0,0.14);flex-shrink:0;"
        />
      </div>
    </div>

    <div class="stagger fade-up" style="display:grid;
      grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;margin-top:48px;">
      {previews.map(p => (
        <div style="background:white;border-radius:12px;overflow:hidden;
          border:1px solid rgba(0,0,0,0.06);
          transition:transform .2s,box-shadow .2s;">
          <div style={`height:140px;background:${p.grad};display:flex;
            align-items:center;justify-content:center;font-size:2.5rem;`}>
            {p.emoji}
          </div>
          <div style="padding:14px 16px;">
            <h4 style="font-family:var(--font-serif);font-size:.95rem;
              font-weight:700;margin-bottom:6px;">{p.title}</h4>
            <p style="font-size:.8rem;color:var(--color-muted);line-height:1.5;">
              {p.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="fade-up" style="text-align:center;">
      <a href={CONFIG.mercadopagoUrl} class="btn-cta">
        Ver precio y comprar
      </a>
    </div>

  </div>
</section>

<style>
  @media (max-width: 768px) {
    #que-es div[style*="grid-template-columns:repeat(3"] {
      grid-template-columns: 1fr !important;
    }
    #que-es div[style*="grid-template-columns:1fr auto"] {
      grid-template-columns: 1fr !important;
    }
    #que-es img[src*="fotosQueVenden"] {
      width: 160px !important;
      margin: 0 auto;
    }
  }
</style>
