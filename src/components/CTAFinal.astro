---
import { CONFIG } from '../config';
const features = [
  '~50 páginas 100 % prácticas',
  'Técnicas con cualquier celular',
  'Luz, escenografía y redes',
  'Checklist descargable',
];
---
<section id="cta-final" style="padding:100px 5%;background:var(--color-teal);color:white;position:relative;overflow:hidden;">

  <div style="max-width:700px;margin:0 auto;text-align:center;">

    <p class="section-tag fade-up"
      style="color:rgba(255,255,255,0.7);">
      Tu turno
    </p>

    <h2 class="fade-up" style="color:white;
      font-size:clamp(2.2rem,4vw,3.2rem);margin-bottom:16px;">
      Empezá a vender con fotos que impactan
    </h2>

    <p class="fade-up" style="font-size:1.05rem;opacity:.8;
      margin-bottom:36px;font-weight:300;line-height:1.7;">
      Un solo ebook. Un solo pago. Fotos que trabajan para vos.
    </p>

    <div class="stagger fade-up"
      style="display:flex;flex-wrap:wrap;justify-content:center;
      gap:10px;margin-bottom:40px;">
      {features.map(f => (
        <span style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.2);
          padding:6px 16px;border-radius:40px;font-size:.8rem;">
          ✓ {f}
        </span>
      ))}
    </div>

    <div class="fade-up" style="margin-bottom:36px;">
      <div style="font-size:3.5rem;font-family:var(--font-serif);
        font-weight:900;line-height:1;margin-bottom:8px;">
        {CONFIG.precioCompleto}
      </div>
      <div style="opacity:.7;font-size:.875rem;">Pago único — acceso inmediato al PDF</div>
    </div>

    <a href={CONFIG.mercadopagoUrl}
      style="display:inline-block;background:white;color:var(--color-teal);
      font-weight:700;padding:18px 48px;border-radius:50px;
      font-size:1.1rem;font-family:var(--font-serif);
      transition:opacity .2s,transform .2s;
      box-shadow:0 8px 32px rgba(0,0,0,0.15);"
      onmouseover="this.style.opacity='.9';this.style.transform='translateY(-2px)'"
      onmouseout="this.style.opacity='1';this.style.transform='none'">
      Quiero mi ebook →
    </a>

    <p class="fade-up"
      style="margin-top:16px;font-size:.78rem;opacity:.6;">Vinculado a Mercado Pago. Pago seguro.</p>

  </div>
</section>
