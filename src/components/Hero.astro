---
import { CONFIG } from '../config';
---
<section id="hero" style="min-height:100vh;padding:120px 5% 100px;
  background:var(--color-bg);position:relative;overflow:hidden;">

  <!-- Círculo decorativo de fondo -->
  <div style="position:absolute;right:-10%;top:10%;width:50vw;height:50vw;
    background:radial-gradient(circle,rgba(42,157,143,0.06) 0%,transparent 70%);
    border-radius:50%;pointer-events:none;"></div>

  <div style="max-width:1100px;margin:0 auto;display:grid;
    grid-template-columns:1fr 1fr;gap:60px;align-items:center;">

    <!-- Copy -->
    <div class="fade-up">
      <!-- Badge -->
      <div style="display:inline-flex;align-items:center;gap:8px;
        background:var(--color-orange);color:#5a3800;padding:6px 16px;
        border-radius:40px;font-size:.75rem;font-weight:500;
        letter-spacing:.06em;text-transform:uppercase;margin-bottom:24px;">
        <span style="width:6px;height:6px;background:#5a3800;border-radius:50%;"></span>
        Ideal para emprendedores
      </div>

      <!-- H1 -->
      <h1 style="font-size:clamp(2.8rem,5vw,4rem);font-weight:900;
        color:var(--color-ink);margin-bottom:20px;">
        Fotos con celular<br/>
        <em style="color:var(--color-teal);font-style:italic;">que venden</em>
      </h1>

      <!-- Subtítulo -->
      <p style="font-size:1.1rem;line-height:1.65;color:var(--color-ink-2);
        margin-bottom:32px;max-width:480px;font-weight:300;">
        La guía práctica para mostrar tus productos como merecen.
        Sin estudio, sin equipos, sin conocimientos técnicos.
      </p>

      <!-- CTA -->
      <a href={CONFIG.mercadopagoUrl} class="btn-cta">
        Quiero el ebook — {CONFIG.precioCompleto}
      </a>
      <p style="font-size:.8rem;color:var(--color-muted);margin-top:12px;">
        📩 Recibís el PDF en tu email al instante
      </p>
    </div>

    <!-- Portada del ebook -->
    <div class="book-float fade-up" style="display:flex;flex-direction:column;justify-content:center;align-items:center;gap:24px;">
      <img
        src="/images/ebook/portadaEbook.svg"
        alt="Portada del ebook Fotos con Celular que Venden"
        style="
          width:460px;
          max-width:100%;
          filter:drop-shadow(16px 24px 24px rgba(0,0,0,0.25));
        "
      />
      <!-- Pills -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;">
        {['Luz natural bien usada', 'Escenas simples', 'Solo tu celular'].map(item => (
          <div style="display:flex;align-items:center;gap:7px;
            background:white;border:1px solid rgba(42,157,143,0.2);
            padding:8px 14px;border-radius:40px;font-size:.8rem;color:var(--color-ink-2);">
            <span style="width:8px;height:8px;background:var(--color-teal);
              border-radius:50%;flex-shrink:0;"></span>
            {item}
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  @media (max-width: 768px) {
    #hero {
      padding-top: 150px !important;
      padding-bottom: 60px !important;
    }
    #hero > div {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    #hero > div > div:last-child {
      order: -1;
    }
  }
</style>
