---
import { CONFIG } from '../config';
---
<footer style="background:var(--color-ink);padding:40px 5%;">
  <div style="max-width:1100px;margin:0 auto;
    display:flex;justify-content:space-between;align-items:center;
    flex-wrap:wrap;gap:16px;">
    <img src="/images/logo/logo3.svg" alt="Fede Forquera"
      style="height:64px;width:auto;display:block;" />
    <a href={CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer"
      style="color:rgba(255,255,255,0.7);font-size:.875rem;
      transition:color .2s;text-decoration:none;">
      {CONFIG.instagramHandle}
    </a>
    <span style="color:rgba(255,255,255,0.5);font-size:.875rem;">
      © 2026 · Todos los derechos reservados
    </span>
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer > div {
      flex-direction: column !important;
      text-align: center;
    }
  }
</style>
