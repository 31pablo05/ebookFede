---
---
<section id="preview" style="padding:100px 5%;background:var(--color-ink);color:white;">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up">
      <p class="section-tag" style="color:var(--color-teal);">Resultados reales</p>
      <h2 style="color:white;font-size:clamp(2rem,3.5vw,2.8rem);margin-bottom:16px;">
        Pequeños cambios,<br/>gran diferencia
      </h2>
      <p style="color:rgba(255,255,255,0.6);font-size:1.05rem;
        line-height:1.7;margin-bottom:48px;max-width:640px;font-weight:300;">
        Las mismas técnicas del ebook, aplicadas en una sesión real de 30 minutos.
      </p>
    </div>

    <div class="fade-up" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

      <!-- Antes -->
      <div style="border-radius:12px;overflow:hidden;">
        <div style="background:rgba(255,255,255,0.06);padding:12px 20px;
          font-weight:500;font-size:.875rem;display:flex;align-items:center;gap:8px;">
          ❌ Antes
        </div>
        <div style="height:200px;background:rgba(255,255,255,0.03);
          display:flex;align-items:center;justify-content:center;font-size:4rem;">
          🪖
        </div>
        <div style="padding:16px 20px;display:flex;flex-direction:column;gap:6px;">
          {['Luz de techo','Fondo desordenado','Lente angular'].map(t => (
            <div style="display:flex;align-items:center;gap:8px;
              font-size:.8rem;opacity:.7;">
              ✗ {t}
            </div>
          ))}
        </div>
      </div>

      <!-- Después -->
      <div style="border-radius:12px;overflow:hidden;">
        <div style="background:rgba(42,157,143,0.2);padding:12px 20px;
          color:var(--color-teal);font-weight:500;font-size:.875rem;
          display:flex;align-items:center;gap:8px;">
          ✓ Después
        </div>
        <div style="height:200px;background:rgba(42,157,143,0.06);
          display:flex;align-items:center;justify-content:center;font-size:4rem;">
          ☕
        </div>
        <div style="padding:16px 20px;display:flex;flex-direction:column;gap:6px;">
          {['Luz de ventana','Fondo limpio','Zoom natural'].map(t => (
            <div style="display:flex;align-items:center;gap:8px;
              font-size:.8rem;color:#9FE1CB;">
              ✓ {t}
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #preview div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
