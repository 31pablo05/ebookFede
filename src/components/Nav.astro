---
import { CONFIG } from '../config';
---
<nav class="site-nav">
  <div class="nav-inner">

    <!-- Logo -->
    <a href="#hero" class="nav-logo">
      <img src="/images/logo/logo3.svg" alt="Fede Forquera" class="nav-logo-img" />
    </a>

    <!-- Links -->
    <ul class="nav-links">
      <li><a href="#incluye" class="nav-link">Qué incluye</a></li>
      <li><a href="#para-quien" class="nav-link">Para quién</a></li>
      <li><a href="#autor" class="nav-link">El autor</a></li>
    </ul>

    <!-- CTA -->
    <a href={CONFIG.mercadopagoUrl} class="nav-cta">
      <span>Comprá el ebook</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Hamburger mobile -->
    <button class="nav-hamburger" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>

  </div>
</nav>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    /* Barra oscura que contrasta con el hero claro */
    background: rgba(20, 20, 20, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(42, 157, 143, 0.25);
    height: 120px;
  }

  /* Línea teal decorativa en el borde inferior */
  .site-nav::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--color-teal) 30%,
      var(--color-orange) 70%,
      transparent 100%);
    opacity: 0.6;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 5%;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: 110px;
    width: auto;
    display: block;
    animation: logo-float 3.5s ease-in-out infinite;
  }

  @keyframes logo-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  /* Links */
  .nav-links {
    display: flex;
    list-style: none;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 20px; height: 2px;
    background: var(--color-teal);
    border-radius: 2px;
    transition: transform 0.25s ease;
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-link:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* CTA */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-teal);
    color: white;
    padding: 9px 20px;
    border-radius: 40px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(42, 157, 143, 0.4);
  }

  .nav-cta:hover {
    background: var(--color-teal-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(42, 157, 143, 0.5);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: opacity 0.2s;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }

    .nav-inner {
      gap: 16px;
    }

    .nav-cta span {
      display: none;
    }

    .nav-cta {
      padding: 9px 14px;
    }
  }
</style>
