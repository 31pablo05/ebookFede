---
import { CONFIG } from '../config';
---
<nav style="position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(247,238,228,0.92);backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(42,157,143,0.12);
  height:64px;padding:0 5%;display:flex;align-items:center;
  justify-content:space-between;">

  <a href="#hero" style="font-family:var(--font-serif);font-size:1.1rem;
    font-weight:700;color:var(--color-ink);letter-spacing:-0.02em;">
    Fede Forquera
  </a>

  <div class="nav-links" style="display:flex;gap:28px;align-items:center;">
    <a href="#incluye" style="font-size:.875rem;color:var(--color-ink-2);
      transition:color .2s;">Qué incluye</a>
    <a href="#para-quien" style="font-size:.875rem;color:var(--color-ink-2);
      transition:color .2s;">Para quién</a>
    <a href="#autor" style="font-size:.875rem;color:var(--color-ink-2);
      transition:color .2s;">El autor</a>
    <a href={CONFIG.mercadopagoUrl}
      style="background:var(--color-teal);color:white;padding:10px 20px;
      border-radius:40px;font-size:.875rem;font-weight:500;
      transition:background .2s;">
      Comprá el ebook
    </a>
  </div>
</nav>

<style>
  @media (max-width: 768px) {
    .nav-links a:not(:last-child) { display: none; }
  }
</style>
