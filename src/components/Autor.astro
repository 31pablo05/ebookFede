---
import { CONFIG } from '../config';
---
<section id="autor" style="padding:100px 5%;background:var(--color-bg);">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up">
      <p class="section-tag">El autor</p>
      <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);margin-bottom:56px;">
        ¿Por qué Fede<br/>sabe de esto?
      </h2>
    </div>

    <div class="fade-up" style="display:grid;
      grid-template-columns:280px 1fr;gap:56px;align-items:start;">

      <!-- Foto -->
      <div style="flex-shrink:0;">
        <img
          src="/images/about/fedeabout.jpg"
          alt="Fede Forquera"
          style="width:280px;height:320px;border-radius:20px;
            object-fit:cover;object-position:center top;
            border:2px solid rgba(42,157,143,0.2);
            box-shadow:0 8px 32px rgba(0,0,0,0.1);display:block;"
        />
      </div>

      <!-- Bio -->
      <div>
        <div style="font-family:var(--font-serif);font-size:1.8rem;
          font-weight:700;margin-bottom:6px;">
          {CONFIG.autorNombre}
        </div>
        <div style="color:var(--color-teal);font-size:.9rem;
          font-weight:500;margin-bottom:24px;">
          {CONFIG.autorRol}
        </div>

        <!-- Bio items -->
        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:28px;">
          {[
            { e: '👋🏼', t: 'Hola, soy Fede Forquera, fotógrafo y filmmaker publicitario.' },
            { e: '📷', t: 'Me dedico a crear contenido audiovisual de gastronomía, productos y cobertura de eventos.' },
            { e: '❤️',  t: 'Hace más de cuatro años que vivo de mi pasión.' },
            { e: '📍', t: 'Soy del sur, nací en Trelew-Chubut. Crecí rodeado de naturaleza y silencio — eso marcó mi forma de ver y estar en el mundo.' },
            { e: '🏙️', t: 'Desde hace un par de años vivo en Buenos Aires. Dejé atrás varios miedos para apostar a esto: mi proyecto, mi pasión, mi forma de vivir.' },
            { e: '👨🏼‍💼', t: 'Antes quería ser Contador Público. Estudié la carrera, la dejé en tercer año, trabajé en estudios contables y terminé renunciando por hacerme caso a mí mismo.' },
            { e: '✨', t: 'Hoy mi propósito es crear contenido con alma: que no solo muestre, sino que cuente algo.' },
            { e: '👉🏼', t: 'Trabajo con personas comprometidas y marcas que aman lo que hacen, y quieren transmitirlo con autenticidad.' },
          ].map(({ e, t }) => (
            <div style="display:flex;gap:12px;align-items:flex-start;">
              <span style="font-size:1.1rem;flex-shrink:0;line-height:1.6;">{e}</span>
              <p style="font-size:.9rem;color:var(--color-ink-2);line-height:1.65;
                font-weight:300;margin:0;">{t}</p>
            </div>
          ))}
        </div>

        <a href={CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer"
          style="display:inline-flex;align-items:center;gap:8px;
          background:white;border:1px solid rgba(0,0,0,0.08);
          padding:10px 18px;border-radius:40px;
          font-size:.875rem;font-weight:500;color:var(--color-ink);
          transition:border-color .2s,background .2s;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          {CONFIG.instagramHandle}
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #autor div[style*="grid-template-columns:280px"] {
      grid-template-columns: 1fr !important;
    }
    #autor img[src*="fedeabout"] {
      width: 100% !important;
      height: 260px !important;
    }
  }
</style>
