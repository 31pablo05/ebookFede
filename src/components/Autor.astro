---
import { CONFIG } from '../config';
---
<section id="autor" style="padding:100px 5%;background:var(--color-bg);">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="fade-up">
      <p class="section-tag">El autor</p>
      <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);margin-bottom:56px;">
        ¿Por qué Fede<br/>sabe de esto?
      </h2>
    </div>

    <div class="fade-up" style="display:grid;
      grid-template-columns:200px 1fr;gap:56px;align-items:start;">

      <!-- Foto (placeholder) -->
      <div style="width:200px;height:200px;border-radius:20px;
        background:var(--color-teal-light);
        border:2px solid rgba(42,157,143,0.2);
        display:flex;align-items:center;justify-content:center;
        flex-direction:column;gap:8px;flex-shrink:0;">
        <span style="font-size:3rem;">📷</span>
        <span style="font-size:.75rem;color:var(--color-muted);
          text-align:center;padding:0 12px;">
          Foto de Fede próximamente
        </span>
      </div>

      <!-- Bio -->
      <div>
        <div style="font-family:var(--font-serif);font-size:1.8rem;
          font-weight:700;margin-bottom:6px;">
          {CONFIG.autorNombre}
        </div>
        <div style="color:var(--color-teal);font-size:.9rem;
          font-weight:500;margin-bottom:20px;">
          {CONFIG.autorRol}
        </div>
        <p style="font-size:.95rem;color:var(--color-ink-2);line-height:1.75;
          margin-bottom:24px;font-weight:300;">
          Fede lleva años fotografiando y filmando proyectos publicitarios.
          Trabajó con marcas, emprendedores y productos que necesitaban imágenes
          que vendieran — no solo que se vean lindas.<br/><br/>
          Este ebook nació de ver emprendedores con productos increíbles pero fotos
          que no los representaban. Quiso que cualquier persona, sin experiencia
          ni equipos, pudiera tomar fotos que transmitan el valor real de lo que hacen.
        </p>
        <a href={CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer"
          style="display:inline-flex;align-items:center;gap:8px;
          background:white;border:1px solid rgba(0,0,0,0.08);
          padding:10px 18px;border-radius:40px;
          font-size:.875rem;font-weight:500;color:var(--color-ink);
          transition:border-color .2s,background .2s;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          {CONFIG.instagramHandle}
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #autor div[style*="grid-template-columns:200px"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
