---
import { CONFIG } from '../config';
---
<section id="autor" class="autor section-base">
  <div class="container">
    <span class="section-tag fade-up">El autor</span>
    <h2 class="fade-up">¿Por qué Fede<br />sabe de esto?</h2>

    <div class="autor-grid fade-up">
      <!-- Foto -->
      <div class="autor-foto">
        <div class="foto-placeholder">
          <span>📷</span>
          <p>Foto de Fede próximamente</p>
        </div>
      </div>

      <!-- Texto -->
      <div class="autor-bio">
        <p class="autor-nombre">{CONFIG.autorNombre}</p>
        <p class="autor-rol">{CONFIG.autorRol}</p>
        <div class="autor-texto">
          <p>
            Fede lleva años fotografiando y filmando proyectos publicitarios.
            Trabajó con marcas, emprendedores y productos que necesitaban imágenes
            que vendieran — no solo que se vean lindas.
          </p>
          <p>
            Este ebook nació de ver emprendedores con productos increíbles pero fotos
            que no los representaban. Quiso que cualquier persona, sin experiencia ni
            equipos, pudiera tomar fotos que transmitan el valor real de lo que hacen.
          </p>
        </div>
        <a
          href={CONFIG.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="autor-ig"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          {CONFIG.instagramHandle}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .autor {
    background: var(--bg);
  }

  .autor h2 {
    margin-bottom: 48px;
  }

  .autor-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 60px;
    align-items: center;
  }

  .foto-placeholder {
    background: var(--teal-light);
    border-radius: 20px;
    aspect-ratio: 4/5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--teal-dark);
  }

  .foto-placeholder span {
    font-size: 3.5rem;
  }

  .foto-placeholder p {
    font-size: 0.85rem;
    font-weight: 500;
    text-align: center;
  }

  .autor-foto img {
    width: 100%;
    border-radius: 20px;
    object-fit: cover;
  }

  .autor-nombre {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .autor-rol {
    font-size: 0.9rem;
    color: var(--teal);
    font-weight: 500;
    margin-bottom: 24px;
  }

  .autor-texto {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .autor-texto p {
    font-size: 0.98rem;
    color: var(--ink-2);
    line-height: 1.7;
  }

  .autor-ig {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1.5px solid var(--teal);
    border-radius: 40px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--teal);
    transition: background 0.2s, color 0.2s;
  }

  .autor-ig:hover {
    background: var(--teal);
    color: white;
  }

  @media (max-width: 768px) {
    .autor-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
